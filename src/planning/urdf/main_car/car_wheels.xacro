<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="wheel_inertial" params="mass radius width">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${mass * radius * radius / 2.0}"
        ixy="0"
        ixz="0"
        iyy="${mass * (3.0 * radius * radius + width * width) / 12.0}"
        iyz="0"
        izz="${mass * (3.0 * radius * radius + width * width) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="photo_wheel" params="name parent x y z radius width">
    <link name="${name}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${width}"/>
        </geometry>
        <material name="mat_black"/>
      </visual>
      <visual>
        <origin xyz="0 0 0.001" rpy="${pi / 2.0} 0 0"/>
        <geometry>
          <cylinder radius="${radius * 0.62}" length="${width + 0.004}"/>
        </geometry>
        <material name="mat_blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${width}"/>
        </geometry>
      </collision>
      <xacro:wheel_inertial mass="0.20" radius="${radius}" width="${width}"/>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.05" friction="0.1"/>
    </joint>
  </xacro:macro>
</robot>
